<!-- EXAMPLE 1 -->

<?xml version="1.0" ?>
<!-- The root element of any robot description file. Every element must sit inside these robot tags. -->
<robot name="my_custom_robot">

  <!-- ========================================== -->
  <!-- MATERIAL DEFINITIONS (GLOBAL COLORS)   -->
  <!-- ========================================== -->
  <!-- These materials can be reused by name anywhere inside the URDF visual tags. -->

  <!-- Defines a reusable material named 'blue' -->
  <material name="blue">
    <!-- RGBA: Red, Green, Blue, Alpha (transparency). Values range from 0.0 to 1.0 -->
    <color rgba="0.2 0.2 1.0 1.0"/>
  </material>

  <!-- Defines a reusable material named 'grey' -->
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>


  <!-- ========================================== -->
  <!-- LINK 1: BASE LINK (The Center Point)     -->
  <!-- ========================================== -->
  <!-- Crucial standard practice: base_link has no physical properties. -->
  <!-- It acts as the absolute center/origin point of the robot coordinate system. -->
  <link name="base_link">
    <!-- Purposely left empty. Physical parts will be offset from this point. -->
  </link>


  <!-- ========================================== -->
  <!-- LINK 2: CHASSIS (The Main Body)         -->
  <!-- ========================================== -->
  <!-- This is the actual physical hull/body of our robot. -->
  <link name="chassis_link">

    <!-- 👁️ VISUAL: Controls what the robot looks like in visualization software like RViz -->
    <visual>
      <!-- Origin shifts the visual shape relative to this link's local coordinate frame -->
      <!-- xyz = X(forward/back) Y(left/right) Z(up/down) in meters -->
      <!-- rpy = Roll, Pitch, Yaw in radians (0.0 0.0 0.0 means no rotation) -->
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <!-- Geometry defines the raw shape. Options include <box/>, <cylinder/>, or <sphere/> -->
      <geometry>
        <!-- A box shape. size="Width(X) Length(Y) Height(Z)" in meters -->
        <box size="0.5 0.3 0.15"/>
        <!-- Note: If using CAD files, you would use: <mesh filename="package://my_pkg/meshes/body.dae"/> instead -->
      </geometry>
      <!-- Assigns our globally defined color to this specific visual geometry -->
      <material name="blue"/>
    </visual>

    <!-- COLLISION: The invisible boundary used by physics simulators (Gazebo) to calculate impacts -->
    <!-- Keeps calculation light. Usually a simplified box or cylinder version of the visual tag -->
    <collision>
      <!-- Typically matches the visual origin exactly so boundaries align with looks -->
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <!-- Matching the box size of the visual tag for exact boundary collision -->
        <box size="0.5 0.3 0.15"/>
      </geometry>
    </collision>

    <!-- INERTIAL: Defines physical mass and rotational resistance for dynamics engines -->
    <!-- Essential for simulators like Gazebo; without this, the robot cannot drop, slide, or flip -->
    <inertial>
      <!-- The Center of Mass (CoM) position relative to this link's origin frame -->
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <!-- Total mass of this specific link component in kilograms -->
      <mass value="5.0"/>
      <!-- Inertia Tensor Matrix (ixx, ixy, ixz, iyy, iyz, izz). Expresses resistance to rotational acceleration. -->
      <!-- Values computed via standard formulas based on mass and geometric dimensions -->
      <inertia ixx="0.046875" ixy="0.0" ixz="0.0" iyy="0.113541" iyz="0.0" izz="0.141666"/>
    </inertial>

  </link>


  <!-- ========================================== -->
  <!-- JOINT 1: FIXED JOINT (Connects Body)    -->
  <!-- ========================================== -->
  <!-- Joints attach a child link to a parent link. -->
  <joint name="base_to_chassis_joint" type="fixed">
    <!-- The link that remains stationary or acts as the source frame -->
    <parent link="base_link"/>
    <!-- The link being attached and moved relative to the parent -->
    <child link="chassis_link"/>
    <!-- The rigid offset distance of the child link relative to the parent link -->
    <!-- Here we lift the chassis body slightly off the absolute ground floor zero mark -->
    <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
  </joint>


  <!-- ========================================== -->
  <!-- LINK 3: WHEEL (Moving Part)             -->
  <!-- ========================================== -->
  <!-- A separate physical component that will spin freely -->
  <link name="left_wheel_link">

    <!-- Visual look of the wheel -->
    <visual>
      <!-- Wheels are cylinders. Standard cylinders stand straight up along the Z-axis. -->
      <!-- We rotate it by 1.5708 radians (90 degrees) on the Pitch (Y) axis to lay it flat like a vehicle wheel. -->
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <!-- radius="meters" length="thickness of wheel in meters" -->
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>

    <!-- Collision limits of the wheel -->
    <collision>
      <!-- Match visual orientation precisely so it rolls cleanly along physics planes -->
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>

    <!-- Inertial physics properties of the wheel -->
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.5"/>
      <!-- Inertia values calculated using a standard solid cylinder mathematical formula -->
      <inertia ixx="0.001354" ixy="0.0" ixz="0.0" iyy="0.001354" iyz="0.0" izz="0.0025"/>
    </inertial>

  </link>


  <!-- ========================================== -->
  <!-- JOINT 2: CONTINUOUS JOINT (The Axle)     -->
  <!-- ========================================== -->
  <!-- 'continuous' type means a joint that rotates infinitely around an axis with no limits (like a wheel). -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="left_wheel_link"/>
    <!-- Where the wheel axle mounts on the chassis. -->
    <!-- Shifted slightly back on X (-0.1), pushed outward on Y (left side = 0.175), dropped down on Z (-0.05) -->
    <origin xyz="-0.1 0.175 -0.05" rpy="0.0 0.0 0.0"/>
    <!-- Specifies which standard axis vector the child link spins around. -->
    <!-- xyz="0 1 0" locks rotation perfectly around the Y-axis (forward/backward rolling) -->
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

</robot>




<!-- EXAMPLE 2 -->

<!-- so instead of ... -->

<?xml version="1.0"?>
<robot name="my_robot">

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder length="0.05" raduis="0.1"/>
            </geometry>
        </visual>
    </link>
    
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder length="0.05" raduis="0.1"/>
            </geometry>
        </visual>
    </link>

</robot>

<!-- write a macro once and call it twice ... -->

<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot">

    <xacro:macro name="wheel" paramas="side">
        <link name="${side}_wheel">
            <visual>
                <geometry>
                    <cylinder length="0.05" raduis="0.1"/>
                </geometry>
            </visual>
        </link>
    </xacro:macro>

    <xacro:wheel side="left"/>
    <xacro:wheel wide="right"/>

</robot>

