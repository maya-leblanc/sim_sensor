<?xml version="1.0"?>
<robot name="sim_sensor_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========== PROPERTIES (xacro variables) ========== -->
  <xacro:property name="base_radius"   value="0.2"/>
  <xacro:property name="base_length"   value="0.2"/>
  <xacro:property name="arm_length"    value="0.5"/>
  <xacro:property name="arm_width"     value="0.1"/>
  <xacro:property name="finger_length" value="0.3"/>

  <!-- ========== BASE LINK ========== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${base_length}" radius="${base_radius}"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${base_length}" radius="${base_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="12"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>
  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ========== BASE TOP ========== -->
  <link name="base_top">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.11"/>
      <geometry>
        <cylinder radius="${base_radius}" length="0.1"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <gazebo reference="base_top">
    <material>Gazebo/Red</material>
  </gazebo>

  <joint name="base_link_to_base_top" type="continuous">
    <parent link="base_link"/>
    <child link="base_top"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ========== ARM 1 (shoulder) ========== -->
  <link name="base_arm">
    <visual>
      <origin xyz="${arm_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_width}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.1 0.8 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="${arm_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <gazebo reference="base_arm">
    <material>Gazebo/Blue</material>
  </gazebo>

  <joint name="base_top_to_base_arm" type="revolute">
    <parent link="base_top"/>
    <child link="base_arm"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <!-- ========== ARM 2 (elbow) ========== -->
  <link name="middle_arm">
    <visual>
      <origin xyz="${arm_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_width}"/>
      </geometry>
      <material name="blue2">
        <color rgba="0.1 0.4 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="${arm_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <gazebo reference="middle_arm">
    <material>Gazebo/SkyBlue</material>
  </gazebo>

  <joint name="base_arm_to_middle_arm" type="revolute">
    <parent link="base_arm"/>
    <child link="middle_arm"/>
    <origin xyz="${arm_length} 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <!-- ========== WRIST ========== -->
  <link name="wrist">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 1.5707 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="grey2">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <gazebo reference="wrist">
    <material>Gazebo/Grey</material>
  </gazebo>

  <joint name="middle_arm_to_wrist" type="continuous">
    <parent link="middle_arm"/>
    <child link="wrist"/>
    <origin xyz="${arm_length} 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- ========== FINGER LEFT ========== -->
  <link name="finger_left">
    <visual>
      <origin xyz="${finger_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${finger_length} 0.05 0.02"/>
      </geometry>
      <material name="silver">
        <color rgba="0.8 0.8 0.8 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="finger_left">
    <material>Gazebo/White</material>
  </gazebo>

  <joint name="wrist_to_finger_left" type="revolute">
    <parent link="wrist"/>
    <child link="finger_left"/>
    <origin xyz="0.1 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0" effort="5" velocity="1"/>
  </joint>

  <!-- ========== FINGER RIGHT ========== -->
  <link name="finger_right">
    <visual>
      <origin xyz="${finger_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${finger_length} 0.05 0.02"/>
      </geometry>
      <material name="silver2">
        <color rgba="0.8 0.8 0.8 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="finger_right">
    <material>Gazebo/White</material>
  </gazebo>

  <joint name="wrist_to_finger_right" type="revolute">
    <parent link="wrist"/>
    <child link="finger_right"/>
    <origin xyz="0.1 0 -0.03" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.5" upper="0" effort="5" velocity="1"/>
  </joint>

  <!-- ========== ROS2 CONTROL ========== -->
  <ros2_control name="eliana_control" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="base_link_to_base_top">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="base_top_to_base_arm">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="base_arm_to_middle_arm">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="middle_arm_to_wrist">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wrist_to_finger_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wrist_to_finger_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo plugin that loads ros2_control -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find sim_sensor_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>

