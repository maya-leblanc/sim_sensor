<?xml version="1.0"?>
<robot name="eliana">

  <!-- ===================== BASE ===================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.2"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.2"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="12"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ===================== BASE TOP (spinning disc) ===================== -->
  <link name="base_top">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.11"/>
      <geometry>
        <cylinder radius="0.2" length="0.1"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- spins forever like a motor -->
  <joint name="base_link_to_base_top" type="continuous">
    <parent link="base_link"/>
    <child link="base_top"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ===================== ARM 1 (shoulder) ===================== -->
  <link name="base_arm">
    <visual>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.1 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.1 0.8 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- shoulder joint: up/down -->
  <joint name="base_top_to_base_arm" type="revolute">
    <parent link="base_top"/>
    <child link="base_arm"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <!-- ===================== ARM 2 (elbow) ===================== -->
  <link name="middle_arm">
    <visual>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.1 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.4 0.9 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- elbow joint: attaches at tip of base_arm, bends up/down -->
  <joint name="base_arm_to_middle_arm" type="revolute">
    <parent link="base_arm"/>
    <child link="middle_arm"/>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <!-- ===================== WRIST ===================== -->
  <link name="wrist">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 1.5707 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- wrist joint: rolls/rotates like a screwdriver on X axis -->
  <joint name="middle_arm_to_wrist" type="continuous">
    <parent link="middle_arm"/>
    <child link="wrist"/>
    <origin xyz="0.5 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

<!-- ===================== FINGER LEFT ===================== -->
  <link name="finger_left">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.05 0.02"/>  <!-- flat on Z, wide on Y -->
      </geometry>
      <material name="silver">
        <color rgba="0.8 0.8 0.8 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- flat face claps downward on -Z -->
  <joint name="wrist_to_finger_left" type="revolute">
    <parent link="wrist"/>
    <child link="finger_left"/>
    <origin xyz="0.1 0 0.03" rpy="0 0 0"/>   <!-- offset above center -->
    <axis xyz="0 1 0"/>                        <!-- rotates on Y = claps down -->
    <limit lower="-0.5" upper="0" effort="5" velocity="1"/>
  </joint>

  <!-- ===================== FINGER RIGHT ===================== -->
  <link name="finger_right">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.05 0.02"/>  <!-- same flat shape -->
      </geometry>
      <material name="silver">
        <color rgba="0.8 0.8 0.8 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- flat face claps upward on +Z, mirroring left -->
  <joint name="wrist_to_finger_right" type="revolute">
    <parent link="wrist"/>
    <child link="finger_right"/>
    <origin xyz="0.1 0 -0.03" rpy="0 0 0"/>  <!-- offset below center -->
    <axis xyz="0 -1 0"/>                       <!-- -Y mirrors left finger -->
    <limit lower="-0.5" upper="0" effort="5" velocity="1"/>
  </joint>

</robot>