# example one

<gazebo reference="base_link">
    <material>Gazebo/Grey</material>
</gazebo>

# example two

<gazebo>
    <plugin name="gazebo_ros2_control"
            filename="libgazebo_ros2_control.so">
        <parameters>$(find my_robot_name)/config/controllers.yaml</parameters>
    </plugin>
</gazebo>

# example three

<gazebo>
    <plugin name="diff_drive"
            filename="libgazebo_ros_diff_drive.so">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.4</wheel_separation>
        <wheel_radius>0.1</wheel_radius>
        <publish_odom>true</publish_odom>
        <publish_tf>true</publish_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
    </plugin>
</gazebo>

# example four

ixx = (1/12) * mass * (3*radius^2 + length^2)
iyy (1/12)* mass * (3*radius^2 + length^2)
izz = (1/2) * mass * radius^2

# example 5

# for a cylinder
ixx = (1/12) * mass * (3*radius^2 + length^2)
iyy (1/12)* mass * (3*radius^2 + length^2)
izz = (1/2) * mass * radius^2

# for a box
ixx = (1/12) * mass * (y^2 + z^2)
iyy (1/12)* mass * (x^2 + z^2)
izz = (1/12) * mass * (x^2 + y^2)

# for a sphere
ixx = iyy = izz = (2/5) * mass * radius^2
