# example one. add this to the top before link tags start.

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot_name">

# example two

<xacro:property name="body_radius" value="0.2"/>
<xacro:property name="body_length" value="1.0"/>
